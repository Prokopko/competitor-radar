      "id": "http-refresh",
      "name": "POST /api/refresh",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [1420, 380]
    },
    {
      "parameters": {
        "mode": "runOnceForEachItem",
        "jsCode": "const stats = $input.item.json;\nconst errors = stats.errors || [];\nlet text = `✅ Done: found ${stats.found}, new ${stats.inserted}`;\nif (errors.length) text += `, errors ${errors.length}`;\n\nreturn {\n  json: {\n    chatId: $('Normalize command').item.json.chatId,\n    text,\n  },\n};"
      },
      "id": "code-format-refresh",
      "name": "Format refresh result",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [1660, 380]
    },
