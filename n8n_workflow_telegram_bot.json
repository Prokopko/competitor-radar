    {
      "parameters": {
        "mode": "runOnceForEachItem",
        "jsCode": "const data = $input.item.json;\nconst last = data.last_run || {};\nconst text =\n  `Last run: ${last.finished_at || last.started_at || '—'}\\n` +\n  `Next run: ${data.next_run || '—'}\\n` +\n  `Items tracked: ${data.total_items}`;\n\nreturn {\n  json: {\n    chatId: $('Normalize command').item.json.chatId,\n    text,\n  },\n};"
      },
