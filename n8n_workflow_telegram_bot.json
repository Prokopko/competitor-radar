{
  "name": "Competitor Radar — Telegram bot",
  "nodes": [
    {
      "parameters": {
        "updates": ["message"]
      },
      "id": "telegram-trigger",
      "name": "Telegram Trigger",
      "type": "n8n-nodes-base.telegramTrigger",
      "typeVersion": 1.1,
      "position": [200, 700],
      "webhookId": "REPLACE_ON_FIRST_SAVE",
      "credentials": {
        "telegramApi": {
          "id": "REPLACE_WITH_YOUR_TELEGRAM_CREDENTIAL_ID",
          "name": "Competitor Radar Bot"
        }
      }
    },
    {
      "parameters": {
        "conditions": {
          "options": {
            "caseSensitive": true,
            "leftValue": "",
            "typeValidation": "strict",
            "version": 2
          },
          "combinator": "and",
          "conditions": [
            {
              "id": "cond-allowed-chat",
              "leftValue": "={{ $json.message.chat.id }}",
              "rightValue": "388790734",
              "operator": { "type": "string", "operation": "equals" }
            }
          ]
        },
        "options": {}
      },
      "id": "if-allowed-chat",
      "name": "Allowed chat?",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2.2,
      "position": [440, 700]
    },
    {
      "parameters": {},
      "id": "noop-ignore",
      "name": "Ignore other chats",
      "type": "n8n-nodes-base.noOp",
      "typeVersion": 1,
      "position": [680, 940]
    },
    {
      "parameters": {
        "mode": "runOnceForEachItem",
        "jsCode": "const BUTTONS = {\n  \"🔄 Refresh\": \"/refresh\",\n  \"📰 Digest\": \"/digest\",\n  \"📊 Status\": \"/status\",\n  \"ℹ️ Help\": \"/help\",\n};\n\nconst msg = $input.item.json.message || {};\nconst text = msg.text || \"\";\nconst mapped = BUTTONS[text] || text;\nconst command = mapped.startsWith(\"/\")\n  ? mapped.split(\" \")[0].split(\"@\")[0].toLowerCase()\n  : \"none\";\n\nreturn {\n  json: {\n    command,\n    chatId: msg.chat && msg.chat.id,\n    text: mapped,\n  },\n};"
      },
      "id": "code-normalize",
      "name": "Normalize command",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [680, 700]
    },
    {
      "parameters": {
        "rules": {
          "values": [
            {
              "conditions": {
                "options": {
                  "caseSensitive": true,
                  "leftValue": "",
                  "typeValidation": "strict",
                  "version": 2
                },
                "combinator": "or",
                "conditions": [
                  {
                    "id": "cond-help-1",
                    "leftValue": "={{ $json.command }}",
                    "rightValue": "/start",
                    "operator": { "type": "string", "operation": "equals" }
                  },
                  {
                    "id": "cond-help-2",
                    "leftValue": "={{ $json.command }}",
                    "rightValue": "/help",
                    "operator": { "type": "string", "operation": "equals" }
                  }
                ]
              },
              "renameOutput": true,
              "outputKey": "help"
            },
            {
              "conditions": {
                "options": {
                  "caseSensitive": true,
                  "leftValue": "",
                  "typeValidation": "strict",
                  "version": 2
                },
                "combinator": "or",
                "conditions": [
                  {
                    "id": "cond-refresh",
                    "leftValue": "={{ $json.command }}",
                    "rightValue": "/refresh",
                    "operator": { "type": "string", "operation": "equals" }
                  }
                ]
              },
              "renameOutput": true,
              "outputKey": "refresh"
            },
            {
              "conditions": {
                "options": {
                  "caseSensitive": true,
                  "leftValue": "",
                  "typeValidation": "strict",
                  "version": 2
                },
                "combinator": "or",
                "conditions": [
                  {
                    "id": "cond-digest",
                    "leftValue": "={{ $json.command }}",
                    "rightValue": "/digest",
                    "operator": { "type": "string", "operation": "equals" }
                  }
                ]
              },
              "renameOutput": true,
              "outputKey": "digest"
            },
            {
              "conditions": {
                "options": {
                  "caseSensitive": true,
                  "leftValue": "",
                  "typeValidation": "strict",
                  "version": 2
                },
                "combinator": "or",
                "conditions": [
                  {
                    "id": "cond-status",
                    "leftValue": "={{ $json.command }}",
                    "rightValue": "/status",
                    "operator": { "type": "string", "operation": "equals" }
                  }
                ]
              },
              "renameOutput": true,
              "outputKey": "status"
            }
          ]
        },
        "options": {
          "fallbackOutput": "extra"
        }
      },
      "id": "switch-command",
      "name": "Route command",
      "type": "n8n-nodes-base.switch",
      "typeVersion": 3,
      "position": [920, 700]
    },
    {
      "parameters": {
        "chatId": "={{ $json.chatId }}",
        "text": "=🛰 <b>Competitor Radar</b>\n\nI track fintech competitors for you: app releases, pricing changes, blog posts, news and ads.\n\nEvery Monday I send a digest of the past week here automatically.\n\nUse the buttons below, or these commands:\n/digest — send this week's digest now\n/refresh — run data collection now\n/status — last run / next run / items tracked",
        "additionalFields": {
          "parse_mode": "HTML",
          "disable_web_page_preview": true,
          "reply_markup": "={{ JSON.stringify({ keyboard: [[{text:'🔄 Refresh'},{text:'📰 Digest'}],[{text:'📊 Status'},{text:'ℹ️ Help'}]], resize_keyboard: true }) }}"
        }
      },
      "id": "send-help",
      "name": "Send help",
      "type": "n8n-nodes-base.telegram",
      "typeVersion": 1.2,
      "position": [1180, 140],
      "credentials": {
        "telegramApi": {
          "id": "REPLACE_WITH_YOUR_TELEGRAM_CREDENTIAL_ID",
          "name": "Competitor Radar Bot"
        }
      }
    },
    {
