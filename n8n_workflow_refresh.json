{
  "name": "Competitor Radar → Refresh notification",
  "nodes": [
    {
      "parameters": {
        "httpMethod": "POST",
        "path": "competitor-radar-refresh",
        "responseMode": "lastNode",
        "options": {}
      },
      "id": "webhook-refresh",
      "name": "Refresh webhook",
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 2,
      "position": [240, 300]
    },
    {
      "parameters": {
        "chatId": "={{ $env.TELEGRAM_CHAT_ID }}",
        "text": "=🔄 <b>Competitor Radar refresh</b>\nFound: {{ $json.body.found }}\nNew: {{ $json.body.inserted }}\nErrors: {{ ($json.body.errors || []).length }}",
        "additionalFields": {
          "parse_mode": "HTML",
          "disable_web_page_preview": true
        }
      },
      "id": "telegram-send",
      "name": "Send to Telegram",
      "type": "n8n-nodes-base.telegram",
      "typeVersion": 1.2,
      "position": [520, 300],
      "credentials": {
        "telegramApi": {
          "id": "REPLACE_WITH_YOUR_TELEGRAM_CREDENTIAL_ID",
          "name": "Competitor Radar Bot"
        }
      }
    }
  ],
  "connections": {
    "Refresh webhook": {
      "main": [[{ "node": "Send to Telegram", "type": "main", "index": 0 }]]
    }
  },
  "settings": { "executionOrder": "v1" },
  "pinData": {}
}
