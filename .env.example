TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Timezone for the weekly scheduler (collection Mon 06:00, Telegram digest Mon 09:00).
# Use an IANA name, e.g. Europe/Moscow, Europe/London, UTC. Default: Europe/Moscow.
SCHEDULER_TZ=Europe/Moscow

# Base URL of this app, used by telegram_bot.py
RADAR_API_URL=http://localhost:8000

# Optional: n8n Webhook URL that receives /api/refresh stats (found/inserted/errors),
# e.g. to forward the result to Telegram. See n8n_workflow_refresh.json.
# N8N_REFRESH_WEBHOOK_URL=https://your-n8n.example.com/webhook/competitor-radar-refresh

# Enables the AI trends summary in the digest (Dashboard + Telegram), via OpenRouter.
# Get a key at https://openrouter.ai/ . Without it, a simple rule-based summary is used instead.
OPENROUTER_API_KEY=
# Optional: override the free model used for the summary (see ai_summary.py for the default).
# OPENROUTER_MODEL=openai/gpt-oss-120b:free
